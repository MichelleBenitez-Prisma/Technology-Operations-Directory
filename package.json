{
  "name": "technology-operations-directory",
  "version": "0.2.0",
  "private": true,
  "description": "Internal Technology Operations Directory backend and database.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:api": "tsx watch src/server.ts",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.client.json && vite build",
    "build:api": "tsc -p tsconfig.json",
    "build:client": "tsc -p tsconfig.client.json && vite build",
    "start": "node dist/server.js",
    "test": "node --test --import tsx ./test/systemRecords.test.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:client": "tsc -p tsconfig.client.json --noEmit",
    "db:init": "node scripts/init-database.mjs",
    "db:reset": "node scripts/init-database.mjs --reset"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "lucide-react": "^1.21.0",
    "morgan": "^1.10.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16"
  }
}
