{
  "name": "technology-operations-directory",
  "version": "0.2.0",
  "private": true,
  "description": "Internal Technology Operations Directory backend and database.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "node --test --import tsx ./test/systemRecords.test.ts",
    "typecheck": "tsc --noEmit",
    "db:init": "node scripts/init-database.mjs",
    "db:reset": "node scripts/init-database.mjs --reset"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
